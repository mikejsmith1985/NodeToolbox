#!/usr/bin/env bash
# Forge Workflow Pre-Push Hook
# Generated by Forge Terminal Workflow Architect
# Runs build + test suite before allowing push. Ensures broken code never reaches remote.
# Bypass with: git push --no-verify

set +e
failures=()

echo -e "\033[36mRunning pre-push checks...\033[0m"

# ── Go Build + Test ─────────────────────────────────────────────────────
if [[ -f "go.mod" ]]; then
    echo -e "  \033[36m[Go] Building...\033[0m"
    build_output=$(go build ./cmd/forge/ 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("GO BUILD: go build ./cmd/forge/ failed")
        echo -e "  \033[31m[Go] Build FAILED\033[0m"
        echo "$build_output"
    else
        echo -e "  \033[32m[Go] Build passed\033[0m"
    fi

    echo -e "  \033[36m[Go] Testing...\033[0m"
    test_output=$(go test ./... 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("GO TEST: go test ./... failed")
        echo -e "  \033[31m[Go] Tests FAILED\033[0m"
        echo "$test_output"
    else
        echo -e "  \033[32m[Go] Tests passed\033[0m"
    fi
fi

# ── Frontend Build + Test ───────────────────────────────────────────────
if [[ -f "frontend/package.json" ]]; then
    echo -e "  \033[36m[Frontend] Testing...\033[0m"
    pushd frontend > /dev/null
    vitest_output=$(npx vitest run 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("FRONTEND TEST: npx vitest run failed")
        echo -e "  \033[31m[Frontend] Tests FAILED\033[0m"
        echo "$vitest_output"
    else
        echo -e "  \033[32m[Frontend] Tests passed\033[0m"
    fi
    popd > /dev/null
fi

# ── Client (React SPA) Typecheck ────────────────────────────────────────
# This repo's SPA lives in client/ (not frontend/). Run the SAME project build the
# release uses — `tsc -b` — so a type error that `tsc --noEmit` or `vite build` tolerate
# (e.g. a missing type import) is caught here, before it can reach main and break a release.
#
# Skip cache: a release pushes several times in a row (main, tag, branch cleanup) with an
# identical working tree, and re-typechecking the same code adds minutes for zero safety.
# The git tree hash of client/ identifies its exact committed content, so when the working
# tree is clean and that same hash already passed a typecheck, this run is skipped.
if [[ -f "client/package.json" ]]; then
    typecheck_cache_file=".forge/cache/pre-push-client-tree"
    client_tree_hash=$(git rev-parse "HEAD:client" 2>/dev/null)
    client_dirty_files=$(git status --porcelain -- client 2>/dev/null)
    if [[ -n "$client_tree_hash" && -z "$client_dirty_files" && -f "$typecheck_cache_file" && "$(cat "$typecheck_cache_file")" == "$client_tree_hash" ]]; then
        echo -e "  \033[32m[Client] Typecheck skipped — client/ tree already verified (${client_tree_hash:0:12})\033[0m"
    else
        echo -e "  \033[36m[Client] Typechecking (tsc -b)...\033[0m"
        pushd client > /dev/null
        typecheck_output=$(npx tsc -b 2>&1)
        typecheck_exit=$?
        popd > /dev/null
        if [[ $typecheck_exit -ne 0 ]]; then
            failures+=("CLIENT TYPECHECK: npx tsc -b failed")
            echo -e "  \033[31m[Client] Typecheck FAILED\033[0m"
            echo "$typecheck_output"
        else
            echo -e "  \033[32m[Client] Typecheck passed\033[0m"
            # Only a clean tree can be trusted for future skips — uncommitted client/
            # edits were typechecked here but are not represented by the tree hash.
            if [[ -n "$client_tree_hash" && -z "$client_dirty_files" ]]; then
                mkdir -p .forge/cache
                echo "$client_tree_hash" > "$typecheck_cache_file"
            fi
        fi
    fi
fi

# ── Report ──────────────────────────────────────────────────────────────
if [[ ${#failures[@]} -gt 0 ]]; then
    echo -e "\n\033[31mPRE-PUSH FAILURES (blocking):\033[0m"
    for f in "${failures[@]}"; do echo -e "  \033[31m* $f\033[0m"; done
    echo -e "\033[31mPush blocked. Fix failures or use --no-verify to bypass.\033[0m"
    exit 1
fi

echo -e "\033[32mPre-push checks passed\033[0m"
exit 0
