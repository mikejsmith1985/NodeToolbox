# NodeToolbox — Environment Variable Reference
#
# Copy this file to .env and fill in your values, OR set these variables in your
# system environment. Environment variables take priority over toolbox-proxy.json.
#
# In GPO-locked corporate environments, prefer toolbox-proxy.json (set via the
# /setup wizard) over .env files to avoid shell profile restrictions.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the proxy server listens on (default: 5555)
TBX_PORT=5555

# ── Jira ──────────────────────────────────────────────────────────────────────

# Jira instance base URL (no trailing slash)
TBX_JIRA_URL=https://yourcompany.atlassian.net

# Personal Access Token — recommended for SSO/Okta environments
JIRA_PAT=your-jira-pat-here

# Basic Auth credentials (alternative to PAT — not recommended for SSO environments)
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token-here

# ── ServiceNow ────────────────────────────────────────────────────────────────

# ServiceNow instance base URL (no trailing slash)
TBX_SNOW_URL=https://yourcompany.service-now.com

# ServiceNow credentials
SERVICE_NOW_USERNAME=your-username
SERVICE_NOW_PASSWORD=your-password

# ── GitHub ────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token — injected as Bearer on all /github-proxy/* requests
# Minimum scope: repo:read (for branch/PR monitoring), read:user
GITHUB_TOKEN=ghp_your_token_here

# ── Confluence ────────────────────────────────────────────────────────────────

# Confluence Cloud tenant base URL (no trailing slash)
# Paths like /wiki/rest/api/space are appended by the browser and forwarded as-is.
TBX_CONFLUENCE_URL=https://zilverton.atlassian.net

# Atlassian Cloud API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
# This is your Atlassian account email + a Cloud API token (NOT the same as the self-hosted Jira PAT).
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token-here

# ── TLS / SSL ─────────────────────────────────────────────────────────────────

# Set to "false" only in corporate networks with SSL inspection (e.g. Zscaler)
# that replace server certificates with their own CA. Default: true (verify certs)
TBX_SSL_VERIFY=true
