{
  "name": "node-toolbox",
  "version": "0.70.0",
  "description": "Enterprise proxy server for Jira, GitHub, and ServiceNow — Express-based, zero terminal configuration",
  "keywords": [
    "toolbox",
    "proxy",
    "jira",
    "github",
    "servicenow",
    "enterprise"
  ],
  "homepage": "https://github.com/mikejsmith1985/NodeToolbox",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mikejsmith1985/NodeToolbox.git"
  },
  "license": "MIT",
  "private": true,
  "main": "server.js",
  "scripts": {
    "build:pi-review-engine": "esbuild client/src/views/ArtView/piReviewEngine.entry.ts --bundle --platform=node --format=cjs --outfile=src/services/generated/piReviewEngine.cjs",
    "prestart": "npm run build:pi-review-engine",
    "start": "node server.js",
    "start:open": "node server.js --open",
    "create-launcher": "node scripts/create-launcher.js",
    "prebuild:exe": "npm run build:pi-review-engine",
    "build:exe": "pkg server.js --targets node20-win-x64 --output dist/NodeToolbox.exe",
    "build:client": "cd client && npm run build",
    "local-release": "powershell -ExecutionPolicy Bypass -File scripts\\local-release.ps1",
    "pretest": "npm run build:pi-review-engine",
    "test": "jest --forceExit",
    "pretest:dom": "npm run build:pi-review-engine",
    "test:dom": "node --test test/server-dom/piReviewEngine.spec.js test/server-dom/piReviewRefresh.spec.js",
    "test:unit": "jest --testPathPattern='test/unit/' --forceExit",
    "test:integration": "jest --testPathPattern='test/integration/' --forceExit",
    "test:client": "cd client && npm test",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "linkedom": "^0.18.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "assets": [
      "client/dist/**/*"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.forge/"
    ],
    "testMatch": [
      "**/test/**/*.test.js",
      "**/src/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "server.js"
    ]
  }
}
